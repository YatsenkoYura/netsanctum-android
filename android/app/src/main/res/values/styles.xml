<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window as soon as the process has started -->
    <style name="LaunchTheme" parent="android:Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
    </style>
    <!-- Theme applied to the Android Window after Flutter has loaded -->
    <style name="NormalTheme" parent="android:Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
